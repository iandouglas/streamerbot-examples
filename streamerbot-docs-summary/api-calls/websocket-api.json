    "summary": "When interacting with the Streamer.bot WebSocket Server, you may want to access your instance from other devices, such as your phone or another computer.\n\nDepending on your use case, there are a few different ways to achieve this.\n\nLocal Area Network (LAN)\nYou can access your Streamer.bot instance over your local network by simply using the local IP address of the machine running Streamer.bot.",
    "parameters": [],
    "variables": [],
    "commonVariables": [],
    "codeBlocks": [
      {
        "language": "js",
        "label": "",
        "code": "const client = new StreamerbotClient({\n  host: '192.168.1.10' // Replace with your local IP address\n});"
      },
      {
        "language": "bash",
        "label": "Terminal",
        "code": "tailscale serve 8080"
      },
      {
        "language": "js",
        "label": "",
        "code": "const client = new StreamerbotClient({\n  host: 'device.my-tailnet.ts.net',\n  port: 443,\n  scheme: 'wss'\n});"
      }
    ],
    "codeBlockCount": 3
