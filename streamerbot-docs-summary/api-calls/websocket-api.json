  {
    "title": "Authentication",
    "name": null,
    "description": "How to authenticate with the WebSocket server",
    "version": "0.2.5",
    "route": "/api/websocket/guide/authentication",
    "sourceUrl": "https://docs.streamer.bot/api/websocket/guide/authentication",
    "sourcePath": "3.api/4.websocket/0.guide/4.authentication.md",
    "headings": [
      "Authenticating with Client",
      "Authentication Steps",
      "Hello Request",
      "Authenticate Request",
      "Example in JavaScript"
    ],
    "summary": "Authentication was added to the WebSocket server in Streamer.bot v0.2.5.\n\nAuthentication is **optional** and can be enabled or disabled in the WebSocket settings.\n- SendMessage is the only request where authentication is required.\n\nAuthenticating with Client",
    "parameters": [],
    "variables": [],
    "commonVariables": [],
    "codeBlocks": [
      {
        "language": "js",
        "label": "",
        "code": "const client = new StreamerbotClient({\n  password: 'MySuperSecretPassword'\n});"
      },
      {
        "language": "json",
        "label": "hello.json",
        "code": "{\n  \"timestamp\": \"<ISO8601_string>\",\n  \"session\": \"<string>\",\n  \"request\": \"Hello\",\n  \"info\": {\n    \"instanceId\": \"<string>\",\n    \"name\": \"<string>\",\n    \"version\": \"<string>\",\n    \"os\": \"<string>\",\n    \"osVersion\": \"<string>\",\n    \"mode\": \"ui\",\n    \"darkMode\": true,\n    \"source\": \"websocketServer\"\n  },\n  \"authentication\": {\n    \"salt\": \"<base64_string>\",\n    \"challenge\": \"<base64_string>\"\n  }\n}"
      },
      {
        "language": "js",
        "label": "Authenticate.json",
        "code": "{\n  \"request\": \"Authenticate\",\n  \"id\": \"<request_id>\", // Any unique ID you want to use\n  \"authentication\": \"<authentication_string>\" // Your generated authentication string\n}"
      },
      {
        "language": "js",
        "label": "example.js",
        "code": "import crypto from 'crypto';\n\nconst { salt, challenge } = data.authentication;\nconst password = 'your_websocket_password';\nconst secret = crypto.createHash('sha256').update(password + salt, 'utf8').digest('base64');\nconst authentication = crypto.createHash('sha256').update(secret + challenge, 'utf8').digest('base64');\n\nconst authRequest = {\n  id: '1',\n  request: 'Authenticate',\n  authentication\n};\nws.send(JSON.stringify(authRequest));"
      }
    ],
    "codeBlockCount": 4
  },
