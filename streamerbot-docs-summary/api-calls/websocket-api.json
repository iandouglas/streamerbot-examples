  {
    "title": "Using the Client",
    "name": null,
    "description": "Connect to the Streamer.bot WebSocket Server using the official client package",
    "version": null,
    "route": "/api/websocket/guide/client",
    "sourceUrl": "https://docs.streamer.bot/api/websocket/guide/client",
    "sourcePath": "3.api/4.websocket/0.guide/1.client.md",
    "headings": [
      "Installation",
      "Usage",
      "Execute Actions",
      "Event Handling"
    ],
    "summary": "The easiest way to interact with the WebSocket Server is by using the official client package\n\nInstallation\nInstall the package via your preferred package manager:\n\nOr import it directly in the browser via a CDN:",
    "parameters": [],
    "variables": [],
    "commonVariables": [],
    "codeBlocks": [
      {
        "language": "bash",
        "label": "pnpm",
        "code": "pnpm install @streamerbot/client"
      },
      {
        "language": "bash",
        "label": "npm",
        "code": "npm install @streamerbot/client"
      },
      {
        "language": "bash",
        "label": "yarn",
        "code": "yarn add @streamerbot/client"
      },
      {
        "language": "html",
        "label": "index.html",
        "code": "<script src=\"https://cdn.jsdelivr.net/npm/@streamerbot/client/dist/streamerbot-client.js\"></script>"
      },
      {
        "language": "html",
        "label": "index.html",
        "code": "<script type=\"module\" src=\"index.js\"></script>"
      },
      {
        "language": "js",
        "label": "index.js",
        "code": "import { StreamerbotClient } from 'https://cdn.skypack.dev/@streamerbot/client';"
      },
      {
        "language": "ts",
        "label": "",
        "code": "const client = new StreamerbotClient();"
      },
      {
        "language": "ts",
        "label": "",
        "code": "const client = new StreamerbotClient({\n  host: '127.0.0.1',\n  port: 8080,\n  endpoint: '/',\n  password: 'my-secret-password' // Only needed if authentication is enabled\n});"
      },
      {
        "language": "js",
        "label": "",
        "code": "// Execute an action with actionId \"9c6203fd-363f-4834-983e-b10423c568ea\"\nclient.doAction(\"9c6203fd-363f-4834-983e-b10423c568ea\");\n\n// Execute an action by name\nclient.doAction({ name: \"My Action\" })"
      },
      {
        "language": "js",
        "label": "",
        "code": "// Subscribe to Twitch Chat messages and register an event handler\nclient.on('Twitch.ChatMessage', ({ event, data }) => {\n  // Do something with Twitch Chat data...\n  console.log('Twitch Chat:', data);\n});"
      },
      {
        "language": "js",
        "label": "",
        "code": "// Subscribe to *All* Twitch events\nclient.on('Twitch.*', ({ event, data }) => {\n  // Do something with Twitch data...\n  console.log('Twitch Event:', event.type, data);\n});"
      },
      {
        "language": "js",
        "label": "",
        "code": "// Subscribe to *All events*\nclient.on('*', ({ event, data }) => {\n  // Do something with all events...\n  console.log(`[${event.source}.${event.type}]`, data);\n});"
      }
    ],
    "codeBlockCount": 12
  },
